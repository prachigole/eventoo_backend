DATABASE_URL=postgresql://user:password@localhost:5432/eventoo
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Skip Firebase JWT signature verification. Safe for local dev; never true in production.
DEV_SKIP_AUTH=false

# Skip mDNS advertisement. Leave unset (defaults to false) for normal dev —
# mDNS is how the Flutter app on your phone finds your Mac automatically.
# The test suite sets this to true automatically to avoid Zeroconf re-registration errors.
SKIP_MDNS=false
